{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Treatment",
  "description": "A complete 9-shot commercial treatment generated by the Director agent",
  "type": "object",
  "required": ["id", "title", "tagline", "variables", "characters", "location", "shots"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique treatment ID — timestamp + slug",
      "example": "20260314_une_seconde"
    },
    "title": {
      "type": "string",
      "description": "Treatment title — can be in any language"
    },
    "tagline": {
      "type": "string",
      "description": "One sentence — the emotional premise of the treatment"
    },
    "version": {
      "type": "integer",
      "default": 1,
      "description": "Version number — increments with each Director revision"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "variables": {
      "type": "object",
      "required": ["structure", "collision", "director_tone", "product_mode"],
      "properties": {
        "structure": {
          "type": "string",
          "enum": ["A", "B", "C", "D", "E", "F", "G", "H", "I", "J"],
          "description": "Narrative structure code from Creative Bible"
        },
        "structure_name": {
          "type": "string",
          "description": "Human-readable structure name"
        },
        "collision": {
          "type": "string",
          "enum": ["physical", "audible", "visual", "object", "environmental", "temporal", "implied"]
        },
        "director_tone": {
          "type": "string",
          "enum": ["Glazer", "Jeunet", "Zacharias", "WKW", "Jonze", "Gondry", "Coppola", "LaChapelle", "Romanek", "hybrid"]
        },
        "director_tone_notes": {
          "type": "string",
          "description": "If hybrid, which tones and why"
        },
        "product_mode": {
          "type": "string",
          "enum": ["pure", "ghost", "integrated", "assigned"]
        },
        "product": {
          "type": ["string", "null"],
          "description": "If assigned mode — the brand or product"
        },
        "h_augment": {
          "type": ["string", "null"],
          "enum": ["opening", "closing", null],
          "description": "If Structure H is used as augment — where it appears"
        }
      }
    },
    "characters": {
      "type": "array",
      "minItems": 0,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["id", "quality", "relationship", "emotional_note", "recurring_detail"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Internal reference — A, B, C, D. Not a name."
          },
          "quality": {
            "type": "string",
            "description": "One word physical quality — sharp, soft, weighted, effortless, still, restless, luminous, opaque"
          },
          "relationship": {
            "type": "string",
            "enum": ["belongs here", "alien to it", "passing through"]
          },
          "emotional_note": {
            "type": "string",
            "description": "What they are carrying at the opening — one phrase"
          },
          "recurring_detail": {
            "type": "string",
            "description": "The physical detail that recurs across shots"
          },
          "physical_description": {
            "type": "string",
            "description": "Full prompt-ready physical description — used verbatim in all shots"
          },
          "reference_image_path": {
            "type": ["string", "null"],
            "description": "Path to character reference image if provided"
          }
        }
      }
    },
    "location": {
      "type": "object",
      "required": ["type", "specific_place", "light_sources", "time", "atmospheric"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["transit", "margin", "interior", "threshold", "water"]
        },
        "specific_place": {
          "type": "string",
          "description": "Exact detailed description of the location"
        },
        "light_sources": {
          "type": "array",
          "items": { "type": "string" },
          "description": "All practical light sources present"
        },
        "time": {
          "type": "string",
          "description": "Exact time of day"
        },
        "atmospheric": {
          "type": "string",
          "description": "One dominant atmospheric quality"
        },
        "grade_deviation": {
          "type": ["string", "null"],
          "description": "If location requires deviation from default teal-amber grade"
        }
      }
    },
    "pivot_shot": {
      "type": "object",
      "description": "The image the treatment is built around — always shot 05 in screen order",
      "required": ["concept", "screen_position"],
      "properties": {
        "concept": {
          "type": "string",
          "description": "One sentence describing the pivot shot — what it is and why it stops someone"
        },
        "screen_position": {
          "type": "integer",
          "const": 5
        }
      }
    },
    "shots": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "items": {
        "type": "object",
        "required": [
          "shot_number",
          "screen_position",
          "narrative_position",
          "shot_type",
          "camera_movement",
          "title",
          "narrative_function",
          "emotional_function",
          "description",
          "anamorphic_notes",
          "prompt_brief"
        ],
        "properties": {
          "shot_number": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9
          },
          "screen_position": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9,
            "description": "Position in the edited commercial"
          },
          "narrative_position": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9,
            "description": "Position in the story's actual timeline"
          },
          "is_pivot_shot": {
            "type": "boolean",
            "default": false
          },
          "shot_type": {
            "type": "string",
            "enum": [
              "extreme wide",
              "wide",
              "medium wide",
              "medium",
              "medium close",
              "close",
              "extreme close",
              "insert"
            ]
          },
          "camera_movement": {
            "type": "string",
            "enum": [
              "static",
              "push in",
              "pull back",
              "pan left",
              "pan right",
              "tilt up",
              "tilt down",
              "track left",
              "track right",
              "handheld breathe",
              "slow push",
              "slow pull",
              "crane up",
              "crane down"
            ]
          },
          "title": {
            "type": "string",
            "description": "Short evocative title for the shot"
          },
          "narrative_function": {
            "type": "string",
            "description": "What this shot does in the story"
          },
          "emotional_function": {
            "type": "string",
            "description": "What the audience should feel watching this shot"
          },
          "description": {
            "type": "string",
            "description": "Full shot description — what is in frame, what is happening, what the light is doing"
          },
          "anamorphic_notes": {
            "type": "string",
            "description": "Specific lens character notes for this shot"
          },
          "prompt_brief": {
            "type": "string",
            "description": "Generation-ready prompt string — populated by Cinematographer agent"
          },
          "characters_present": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Character IDs present in this shot — A, B, C, D"
          }
        }
      }
    },
    "narrative_notes": {
      "type": "string",
      "description": "Director notes on structure logic, tone, product placement, anything the agents should know"
    }
  }
}
